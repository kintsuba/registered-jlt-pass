#!/bin/bash

# ステージングされたファイルにUI関連が含まれているかチェック
if git diff --cached --name-only | grep -E '\.(vue|css|scss|html|ts)$' > /dev/null; then
  if [ ! -f ".ui-verified" ]; then
    echo "==========================================================="
    echo "❌ ERROR: UI Verification Token Required!"
    echo "UI関連のファイルが変更されています。"
    echo "コミット前に 'node test-chrome.mjs' を実行してUIの表示確認を行ってください。"
    echo "スクリプトが成功すると '.ui-verified' トークンが生成されコミットが可能になります。"
    echo "==========================================================="
    exit 1
  fi
  
  # トークンを消費して次回のコミットでは再テストを要求する
  rm -f .ui-verified
fi
exit 0
